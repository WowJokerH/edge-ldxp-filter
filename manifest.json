{
  "manifest_version": 3,
  "name": "链动小铺货源增强筛选",
  "version": "1.0.13",
  "description": "在链动小铺货源广场页面添加多页拉取、本地筛选、排序和结果表格。",
  "icons": {
    "16": "assets/icon-16.png",
    "32": "assets/icon-32.png",
    "48": "assets/icon-48.png",
    "128": "assets/icon-128.png"
  },
  "host_permissions": [
    "https://pay.ldxp.cn/*",
    "https://www.ldxp.cn/*"
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "assets/icon-48.png"
      ],
      "matches": [
        "https://pay.ldxp.cn/*",
        "https://www.ldxp.cn/*"
      ]
    }
  ],
  "content_scripts": [
    {
      "matches": [
        "https://pay.ldxp.cn/merchant/my_parent/source_square*",
        "https://www.ldxp.cn/merchant/my_parent/source_square*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "styles.css"
      ],
      "run_at": "document_idle"
    }
  ]
}
