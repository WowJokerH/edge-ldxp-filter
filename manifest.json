{
  "manifest_version": 3,
  "name": "__MSG_extensionName__",
  "version": "1.0.17",
  "default_locale": "zh_CN",
  "description": "__MSG_extensionDescription__",
  "icons": {
    "16": "assets/icon-16.png",
    "32": "assets/icon-32.png",
    "48": "assets/icon-48.png",
    "128": "assets/icon-128.png"
  },
  "host_permissions": [
    "https://pay.ldxp.cn/*",
    "https://www.ldxp.cn/*"
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "assets/icon-48.png"
      ],
      "matches": [
        "https://pay.ldxp.cn/*",
        "https://www.ldxp.cn/*"
      ]
    }
  ],
  "content_scripts": [
    {
      "matches": [
        "https://pay.ldxp.cn/*",
        "https://www.ldxp.cn/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "styles.css"
      ],
      "run_at": "document_idle"
    }
  ]
}
